rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             (!('displayName' in data) || data.displayName is string || data.displayName == null) &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             (!('streak' in data) || data.streak is number) &&
             (!('lastSolvedDate' in data) || data.lastSolvedDate is string || data.lastSolvedDate == null);
    }

    function isValidProblem(data) {
      return data.keys().hasAll(['id', 'uid', 'title', 'topic', 'difficulty', 'status', 'dateAdded']) &&
             data.id is string &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.topic is string &&
             data.difficulty in ['Easy', 'Medium', 'Hard'] &&
             data.status in ['Solved', 'Unsolved', 'Revising'] &&
             data.dateAdded is string;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['id', 'uid', 'title', 'content', 'date']) &&
             data.id is string &&
             data.uid is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             data.date is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(uid) && isValidUserProfile(request.resource.data);
      
      match /problems/{problemId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidProblem(request.resource.data);
        allow update: if isOwner(uid) && isValidProblem(request.resource.data);
        allow delete: if isOwner(uid);
      }
      
      match /notes/{noteId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid) && isValidNote(request.resource.data);
        allow update: if isOwner(uid) && isValidNote(request.resource.data);
        allow delete: if isOwner(uid);
      }
    }
  }
}
